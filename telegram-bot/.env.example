# Database Config
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Bot Config
TELEGRAM_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Cryptographic Config
# Generate a secure 32-byte (256-bit) key. Standard SHA-256 hash will be computed of this string.
ENCRYPTION_KEY=your-super-secret-encryption-key-must-be-long-and-random

# Upgrader.cc Reseller Config
UPGRADER_API_KEY=your-upgrader-cc-reseller-api-key
UPGRADER_API_URL=https://upgrader.cc

# Dev / Mock Mode
# Set to true to simulate payment detections and Upgrader.cc API upgrades without real funds or real keys
USE_MOCK_API=false
