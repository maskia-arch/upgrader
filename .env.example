# =========================================================================
# Spotify Premium Upgrade Bot - Environment Configuration Template
# -------------------------------------------------------------------------
# Copy this file to '.env' for local development or paste these keys
# directly into the "Environment Variables" raw view in Coolify.
# =========================================================================

# [PORT] - Internal Application Port
# The port the Express server binds to inside the container. Caddy will proxy traffic here.
# Default is 8001.
PORT=8001

# [DATABASE_URL] - PostgreSQL Connection String (SECRET)
# Connection details to your server-internal PostgreSQL database service in Coolify.
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Under Coolify, you should use the internal docker network host (e.g. postgresql-xxxxx) rather than public IP.
DATABASE_URL=postgresql://postgres:password@postgresql-service-host:5432/postgres

# [TELEGRAM_TOKEN] - Telegram Bot API Token (SECRET)
# Token obtained from @BotFather for bot control.
TELEGRAM_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# [ENCRYPTION_KEY] - Cryptographic Key (SECRET)
# A secure 32-byte (256-bit) hexadecimal key used to encrypt and decrypt sensitive data (e.g. spotify passwords).
# Generate locally using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-secure-32-byte-hexadecimal-key-must-be-unique-and-random

# [UPGRADER_API_KEY] - Upgrader.cc API Key (SECRET)
# Reseller API key for automated Spotify upgrades. Keep empty if using mock api.
UPGRADER_API_KEY=your-upgrader-cc-reseller-api-key

# [UPGRADER_API_URL] - Upgrader.cc API Base URL
# URL for the Upgrader service API. Defaults to https://upgrader.cc.
UPGRADER_API_URL=https://upgrader.cc

# [USE_MOCK_API] - Developer Mock Mode
# Set to 'true' to simulate payment confirmations and upgrades without spending actual funds or keys.
# Set to 'false' for production execution.
USE_MOCK_API=false
